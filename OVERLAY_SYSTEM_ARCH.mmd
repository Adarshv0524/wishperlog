graph TB
    subgraph Android["🤖 Native Android Layer"]
        SkipOF["OverlayForegroundService<br/>Port 5037"]
        WM["WindowManager<br/>Dynamic Island"]
        SR["SpeechRecognizer<br/>Audio Input"]
        AF["AudioFocusManager<br/>EXCLUSIVE"]
        NR["NoteInputReceiver<br/>LocalBroadcast"]
        
        SkipOF --> WM
        SkipOF --> SR
        SR --> AF
        SkipOF --> NR
    end
    
    subgraph Bridge["🌉 MethodChannel Bridge"]
        MC["MethodChannel<br/>wishperlog/overlay"]
    end
    
    subgraph Flutter["💙 Flutter / Dart Layer"]
        ON["OverlayNotifier<br/>State + Listener"]
        CS["CaptureService<br/>Instant-Save"]
        APS["AiProcessingService<br/>3 Concurrent"]
        INS["IsarNoteStore<br/>Local DB"]
        CUC["CaptureUiController<br/>Broadcasting"]
    end
    
    subgraph Persistence["💾 Persistence"]
        SP["SharedPreferences<br/>Fallback Buffer"]
        IS["Isar SQLite<br/>Local Notes"]
    end
    
    subgraph Cloud["☁️ Cloud"]
        FB["Firestore<br/>Batch Sync"]
        ACL["Analytics Cloud<br/>Logging"]
    end
    
    subgraph AI["🧠 AI Layer"]
        GNC["GeminiNoteClassifier<br/>Async"]
        ACR["AiClassifierRouter<br/>Batch"]
    end
    
    Android -->|invokeMethod| Bridge
    Android -->|setMethodCallHandler| Bridge
    Bridge -->|captureNote| Flutter
    Bridge -->|notifyRecordingStarted| Flutter
    Bridge -->|updateIslandState| Flutter
    Bridge -->|notifySaved| Flutter
    Bridge -->|drainPendingNotes| Flutter
    
    Flutter --> CS
    CS --> INS
    Flutter --> ON
    ON -->|_saveOverlayNote| CS
    
    INS --> SP
    INS --> IS
    SP -->|drain resume| ON
    
    CS -->|ingestRawCapture| CUC
    CUC --> APS
    APS --> AI
    AI --> GNC
    GNC --> ACR
    ACR --> INS
    
    INS --> FB
    FB --> ACL
    
    style Android fill:#90EE90,stroke:#000,color:#000
    style Bridge fill:#87CEEB,stroke:#000,color:#000
    style Flutter fill:#ADD8E6,stroke:#000,color:#000
    style Persistence fill:#FFD700,stroke:#000,color:#000
    style Cloud fill:#F0E68C,stroke:#000,color:#000
    style AI fill:#DDA0DD,stroke:#000,color:#000